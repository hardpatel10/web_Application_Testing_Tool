# Application
APP_NAME="Security Assessment Dashboard"
APP_VERSION=0.1.0
ENVIRONMENT=development

# API
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000

# Logging
LOG_LEVEL=INFO

# Database (PostgreSQL-compatible URL; defaults to local SQLite)
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# Security
# Generate a strong value, e.g.: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-strong-random-value
